{{- $.Scratch.Add "index" slice -}}
{{- range .Site.RegularPages -}}
  {{- /* 魔法在这里：如果 .Title 是空的，就默认使用 .File.BaseFileName (即去掉 .md 后缀的文件名) */ -}}
  {{- $title := .Title | default .File.BaseFileName -}}
  {{- $.Scratch.Add "index" (dict "title" $title "permalink" .RelPermalink) -}}
{{- end -}}
{{- $.Scratch.Get "index" | jsonify -}}